# URL du backend (Railway, etc.) — sans slash final. OBLIGATOIRE au build Netlify si déploiement Git.
# Exemple : https://backendagentai-production.up.railway.app
VITE_API_URL=http://localhost:3001

# OAuth 2.0 — type « Application Web » dans Google Cloud Console
# Origines JS autorisées : http://localhost:3000 (dev Vite) et votre domaine Netlify
# Chargement autorisé : même origine + https://accounts.google.com
VITE_GOOGLE_CLIENT_ID=

# ID du calendrier à lire (défaut : primary). Pour un calendrier partagé, utiliser son adresse e-mail ou l’ID du calendrier
# VITE_GOOGLE_CALENDAR_ID=primary
