# URL du backend (Railway, etc.) — sans slash final. OBLIGATOIRE au build Netlify si déploiement Git.
# Exemple : https://backendagentai-production.up.railway.app
VITE_API_URL=http://localhost:3001

# --- Espace administrateur (connexion sans compte Nest) ---
# En production Netlify : définir ces variables puis redéployer le site.
# En développement local : si absent, identifiants par défaut dans src/config/adminLogin.js
# VITE_ADMIN_EMAIL=admin@votredomaine.com
# VITE_ADMIN_PASSWORD=choisir_un_mot_de_passe_fort
#
# Clé partagée pour l’envoi d’e-mails admin (doit être identique côté Netlify Functions) :
# VITE_WS_ADMIN_API_KEY=une_chaine_longue_aleatoire
# (sur Netlify : WS_ADMIN_API_KEY = même valeur que VITE_WS_ADMIN_API_KEY)

# OAuth 2.0 — type « Application Web » dans Google Cloud Console
# Origines JS autorisées : http://localhost:3000 (dev Vite) et votre domaine Netlify
# Chargement autorisé : même origine + https://accounts.google.com
VITE_GOOGLE_CLIENT_ID=

# Optionnel : un seul agenda (ex. primary). Laisser vide ou `all` = fusion de tous les agendas listés par Google.
# VITE_GOOGLE_CALENDAR_ID=
# VITE_GOOGLE_CALENDAR_ID=primary
