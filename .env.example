# Copier ce fichier : cp .env.example .env  (à la racine du repo, à côté de netlify.toml)
# Puis remplir les valeurs. Netlify CLI charge .env pour `npm run dev:netlify`.

# Obligatoire pour les fonctions test technique (min. 16 caractères)
TECH_TEST_JWT_SECRET=remplace-par-une-chaine-aleatoire-longue

# Obligatoire pour générer / corriger l’exercice IA
OPENAI_API_KEY=

# Lien dans l’e-mail d’invitation (port par défaut de netlify dev)
SITE_URL=http://localhost:8888

# Front : API backend (login, etc.) — adapte si ton API tourne en local
VITE_API_URL=http://localhost:3001
